# Dockerfile.compile – Build a standalone humrine_site binary with PyInstaller
FROM ghcr.io/team-sisante/humrine_site-builder:latest

WORKDIR /app

# Copy the entire project
COPY . .

# ---- PRE‑BUILD: Force Django to initialise and import the missing tag library ----
RUN python -c "import django; django.setup()" && \
    python -c "import blog.templatetags; import blog.templatetags.blog_tags; print('✅ blog.templatetags imported successfully at build time')"

# ---- BUILD: PyInstaller with aggressive inclusion ----
RUN export PYINSTALLER_BUILD=true \
    && export DJANGO_SETTINGS_MODULE=humrine_site.settings.base \
    && export DEBUG=False \
    && export SECRET_KEY=build-key-for-pyinstaller \
    && export DATABASE_URL=sqlite:///tmp/dummy.db \
    && export GCP_PROJECT_ID=dummy-for-build \
    && export SITE_HEADER=dummy \
    && export SITE_TITLE=dummy \
    && export SITE_INDEX_TITLE=dummy \
    && export APP_PROTOCOL=http \
    && export APP_DOMAIN=localhost \
    && export APP_PORT=8000 \
    && export ALLOWED_HOSTS=localhost \
    && export CSRF_TRUSTED_ORIGINS=http://localhost:8000 \
    && export POSTE_PROTOCOL=http \
    && export POSTE_HOSTNAME=localhost \
    && export POSTE_PORT=25 \
    && export POSTE_API_USER=dummy \
    && export POSTE_ADMIN_PASSWORD=dummy \
    && export POSTEIO_DB_HOST=dummy \
    && export POSTEIO_DB_PORT=5432 \
    && export POSTEIO_DB_NAME=dummy \
    && export POSTEIO_DB_USER=dummy \
    && export POSTEIO_DB_PASSWORD=dummy \
    && export ADMIN_PASSWORD=dummy \
    && export SUPPORT_EMAIL=dummy@example.com \
    && export PYTHONPATH=/app \
    && ADD_DATA_ARGS="" \
    && for dir in \
        templates \
        static \
        home/templates \
        home/static \
        pages/templates \
        pages/static \
        affiliate/templates \
        affiliate/static \
        toons/templates \
        toons/static \
        blog/templates \
        blog/static \
        blog/templatetags \
    ; do \
        if [ -d "/app/$dir" ]; then \
            ADD_DATA_ARGS="$ADD_DATA_ARGS --add-data \"$dir:$dir\""; \
            echo "Including: $dir"; \
        else \
            echo "Skipping (not found): $dir"; \
        fi; \
    done \
    && echo "Update: Forcing inclusion of blog.templatetags with hidden imports and paths" \
    && eval pyinstaller \
        --onefile \
        --name humrine_site_linux \
        --clean \
        --collect-all humrine_site \
        --collect-all home \
        --collect-all pages \
        --collect-all affiliate \
        --collect-all toons \
        --collect-all blog \
        --hidden-import blog \
        --hidden-import blog.models \
        --hidden-import blog.templatetags \
        --hidden-import blog.templatetags.blog_tags \
        --paths /app/blog \
        --paths /app \
        --copy-metadata django-bootstrap5 \
        $ADD_DATA_ARGS \
        manage.py