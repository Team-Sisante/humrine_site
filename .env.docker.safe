EMAIL_PORT=dummy_value
EMAIL_HOST_USER=dummy_value
EMAIL_HOST_PASSWORD=<hidden>
EMAIL_USE_TLS=dummy_value
DEFAULT_FROM_EMAIL=dummy_value
