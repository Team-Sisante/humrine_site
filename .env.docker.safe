# ====== EMAIL SETTINGS ======
# Django will automatically use these SMTP_* variables to SEND emails.
# This is currently set to use Gmail, which is reliable for development.
# EMAIL_HOST=smtp.gmail.com  
# EMAIL_PORT=587  
# EMAIL_HOST_USER=paysol.postal@gmail.com  
# EMAIL_HOST_PASSWORD=<hidden> 
# DEFAULT_FROM_EMAIL=paysol.postal@gmail.com  

# # ====== POSTAL SMTP SETTINGS (for Django to send emails) ======
# # These are the same as above, but for Postal service configuration
# SMTP_CERT_PATH=/postal/config/tls/cert.pem  
# SMTP_KEY_PATH=/postal/config/tls/key.pem  
# SIGNING_KEY_PATH=/postal/config/tls/signing.key
# --- START: POSTE.IO SMTP SETTINGS (OPTIONAL) ---
# If you want Django to SEND emails through your local poste.io server instead of Gmail,
# comment out the Gmail settings above and uncomment these.
# NOTE: This may be less reliable as emails sent from a local server often get marked as spam.
