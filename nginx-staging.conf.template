server {
    listen 443 ssl;
    server_name humrine.com;

    ssl_certificate /certs/posteio-cert.pem;
    ssl_certificate_key /certs/posteio-key.pem;

    location / {
        proxy_pass http://__BACKEND_SERVICE__:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
